{
    "js/ts.validate.enabled": true,
    "js/ts.tsdk.path": "node_modules/typescript/lib",
    "files.exclude": {
        "**/node_modules": true
    },
    "search.exclude": {
        "**/node_modules": true
    },
    "js/ts.tsserver.automaticTypeAcquisition.enabled": true,
    "js/ts.tsserver.maxMemory": 4096,
    "js/ts.tsserver.experimental.enableProjectDiagnostics": false,
    "js/ts.preferences.importModuleSpecifierEnding": "minimal",
    "js/ts.tsserver.watchOptions": {
        "excludeDirectories": [
            "**/node_modules"
        ]
    }
}